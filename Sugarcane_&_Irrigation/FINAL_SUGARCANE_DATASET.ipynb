   "source": [
    "from sklearn.linear_model import Lasso\n",
    "\n",
    "lasso = Lasso(alpha=0.01)\n",
    "lasso.fit(x_train_scaled, y_train)\n",
    "\n",
    "lasso_f = x_train_scaled.columns[lasso.coef_ != 0]\n",
    "\n",
    "\n",
    "x_train_selected = x_train_scaled[lasso_f]\n",
    "x_test_selected = x_test_scaled[lasso_f]\n",
    "\n",
    "# ================================\n",
    "# cross valuation\n",
    "# ================================\n",
    "scores_lasso_f = cross_val_score(lin_model, x_train_selected, y_train, cv=5, scoring='r2')\n",
    "print(f\"Mean of lasso_f:{scores_lasso_f.mean()}\")\n",
    "\n",
