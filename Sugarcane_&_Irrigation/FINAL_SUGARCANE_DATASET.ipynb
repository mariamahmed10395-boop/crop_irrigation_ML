    "    axes[i].pie(values,\n",
    "                labels=labels,\n",
    "                colors=colors,\n",
    "                explode=explode,\n",
    "                shadow=True,\n",
    "                startangle=90,\n",
    "                autopct=\"%1.2f%%\",\n",
    "                wedgeprops={'edgecolor': 'black'})\n",
    "\n",
    "    axes[i].set_title(col)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
