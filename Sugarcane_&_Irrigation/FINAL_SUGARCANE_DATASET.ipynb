  {
   "cell_type": "code",
   "execution_count": 250,
   "id": "1f5721f1",
   "metadata": {},
   "outputs": [],
   "source": [
    "def predict_Yield_Quintal_with(test_data):\n",
    "    new_df = pd.DataFrame([test_data])[x_train_scaled_best_f.columns]\n",
    "    # [x_train_best_f.columns]=> to rearrange the columns to get fit\n",
    "\n",
    "    new_scaled = scaler.transform(new_df)\n",
    "\n",
    "    new_scaled_df = pd.DataFrame(new_scaled, columns=x_train_scaled_best_f.columns)\n",
    "\n",
    "    yield_pred = lin_model.predict(new_scaled_df)[0]\n",
    "\n",
    "    return f\"Yield_Quintal_per_Acre: {yield_pred:.2f}\""
   ]
  },
