   "outputs": [],
   "source": [
    "def handle_missing_values(x_train, x_test):\n",
    "\n",
    "# imputing median in numeric\n",
    "    imputer = SimpleImputer(strategy='median')\n",
    "    x_train[num_v] = imputer.fit_transform(x_train[num_v])\n",
    "    x_test[num_v] = imputer.transform(x_test[num_v])\n",
    "\n",
    "    # categorical \n",
    "#     ابقى جربها في داتا تانية\n",
    "#     cat_imputer = SimpleImputer(strategy='most_frequent')\n",
    "#     x_train[cat_v] = cat_imputer.fit_transform(x_train[cat_v])\n",
    "#     x_test[cat_v] = cat_imputer.transform(x_test[cat_v])\n",
    "\n",
    "    return x_train, x_test\n",
    "x_train, x_test= handle_missing_values(x_train, x_test)"
   ]
  },
