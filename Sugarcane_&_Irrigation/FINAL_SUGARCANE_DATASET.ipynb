   "source": [
    "def split_date(x_train, x_test):\n",
    "\n",
    "    for df in [x_train, x_test]:\n",
    "\n",
    "        # Planting\n",
    "        df['Planting_year']   = df['Planting_Date'].dt.year\n",
    "        df['Planting_month']  = df['Planting_Date'].dt.month\n",
    "        df['Planting_hour']   = df['Planting_Date'].dt.hour\n",
    "        df['Planting_dayofweek'] = df['Planting_Date'].dt.dayofweek\n",
    "\n",
    "        # Harvest\n",
    "        df['Harvest_year']  = df['Harvesting_Date'].dt.year\n",
    "        df['Harvest_month'] = df['Harvesting_Date'].dt.month\n",
    "        df['Harvest_hour']  = df['Harvesting_Date'].dt.hour\n",
    "        df['Harvest_dayofweek'] = df['Harvesting_Date'].dt.dayofweek\n",
    "\n",
    "        # Cyclic (Planting)\n",
    "        df['Planting_month_sin'] = np.sin(2*np.pi*df['Planting_month']/12)\n",
    "        df['Planting_month_cos'] = np.cos(2*np.pi*df['Planting_month']/12)\n",
    "\n",
    "        df['Planting_hour_sin'] = np.sin(2*np.pi*df['Planting_hour']/24)\n",
    "        df['Planting_hour_cos'] = np.cos(2*np.pi*df['Planting_hour']/24)\n",
    "\n",
    "        df['Planting_dow_sin'] = np.sin(2*np.pi*df['Planting_dayofweek']/7)\n",
    "        df['Planting_dow_cos'] = np.cos(2*np.pi*df['Planting_dayofweek']/7)\n",
    "\n",
    "        # Sunshine_Hours_hh_mm\n",
    "        df['Sunshine_hour']  = df['Sunshine_Hours_hh_mm'].dt.hour\n",
    "        df['Sunshine_minute']  = df['Sunshine_Hours_hh_mm'].dt.minute\n",
    "\n",
    "        df['Sunshine_hour_sin'] = np.sin(2*np.pi*df['Sunshine_hour']/24)\n",
    "        df['Sunshine_hour_cos'] = np.cos(2*np.pi*df['Sunshine_hour']/24)\n",
    "\n",
    "        df['Sunshine_minute_sin'] = np.sin(2*np.pi*df['Sunshine_minute']/60)\n",
    "        df['Sunshine_minute_cos'] = np.cos(2*np.pi*df['Sunshine_minute']/60)\n",
    "\n",
    "        # Growth\n",
    "        df['growth_days'] = abs((df['Harvesting_Date'] - df['Planting_Date']).dt.days)\n",
    "        # Drop \n",
    "        df.drop([\n",
    "            'Planting_Date','Harvesting_Date',\n",
    "            'Planting_month','Planting_hour','Planting_dayofweek',\n",
    "            'Harvest_month','Harvest_hour','Harvest_dayofweek', 'Sunshine_Hours_hh_mm',\n",
    "            'Sunshine_minute'], axis=1, inplace=True)\n",
    "\n",
    "    x_train, x_test = x_train.align(x_test, join='left', axis=1, fill_value=0)\n",
    "\n",
    "    return x_train, x_test\n",
    "\n",
    "x_train, x_test = split_date(x_train, x_test)\n",
    "x_train"
   ]
  },
