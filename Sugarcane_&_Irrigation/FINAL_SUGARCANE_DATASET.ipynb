    "\n",
    "# ================================\n",
    "# Model training\n",
    "# ================================\n",
    "\n",
    "lin_model.fit(x_train_scaled_best_f, y_train)\n",
    "\n",
    "\n",
    "# ================================\n",
    "# Predictions\n",
    "# ================================\n",
    "\n",
    "y_pred_lin_best_f = lin_model.predict(x_train_scaled_best_f)\n",
    "y_pred_test_best_f = lin_model.predict(x_test_scaled_best_f)\n",
    "\n",
    "\n",
    "\n",
    "# ================================\n",
    "# Train metrics\n",
    "# ================================\n",
    "print(\"Train R2:\", r2_score(y_train, y_pred_lin_best_f))\n",
    "print(\"Train MAE:\", mean_absolute_error(y_train, y_pred_lin_best_f))\n",
    "print(\"Train RMSE:\", np.sqrt(mean_squared_error(y_train, y_pred_lin_best_f)))\n",
    "\n",
    "# ================================\n",
    "# Test metrics\n",
    "# ================================\n",
    "print(\"\\nTest R2:\", r2_score(y_test, y_pred_test_best_f))\n",
    "print(\"Test MAE:\", mean_absolute_error(y_test, y_pred_test_best_f))\n",
    "print(\"Test RMSE:\", np.sqrt(mean_squared_error(y_test, y_pred_test_best_f)))\n",
    "\n",
    "\n",
    "print('\\n----------------------------------\\n')\n",
    "\n",
    "# ================================\n",
    "# cross valuation\n",
    "# ================================\n",
    "scores_all_best_f = cross_val_score(lin_model, x_train_scaled_best_f, y_train, cv=5, scoring='r2')\n",
    "print(\"CV R2 mean:\", scores_all_best_f.mean())\n",
