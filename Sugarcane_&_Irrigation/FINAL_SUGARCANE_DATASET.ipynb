    "Soil_Condition_At_Planting_Moist= 'Soil_Condition_At_Planting_Moist'\n",
    "Planting_Method_Trench= 'Planting_Method_Trench'\n",
    "Planting_Method_Paired_Row= 'Planting_Method_Paired Row'\n",
