    "### Feature Normalization (Z-Score)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 60,
   "id": "19715e42",
   "metadata": {},
   "outputs": [],
   "source": [
    "# x_train.to_csv(\"processed_x_train.csv\", index=False)\n",
    "# x_test.to_csv(\"processed_x_test.csv\", index=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "id": "a27e473b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train mean ≈ -0.000000, std ≈ 1.000000\n",
      "Test mean ≈ 0.001408, std ≈ 1.001623\n"
     ]
    }
   ],
   "source": [
    "scaler = StandardScaler()\n",
    "def z_scoring(x_train, x_test):\n",
    "               x_train_scaled = pd.DataFrame(\n",
    "               scaler.fit_transform(x_train),\n",
    "               columns=x_train.columns,\n",
    "               index=x_train.index)\n",
    "\n",
    "               x_test_scaled = pd.DataFrame(\n",
    "               scaler.transform(x_test),\n",
    "               columns=x_test.columns,\n",
    "               index=x_test.index)\n",
    "\n",
    "               # print(f\"Normalized {x_train.shape[1]} features\")\n",
    "               # print(f\"Training data: mean={np.mean(x_train_scaled):.6f}, std={np.std(x_train_scaled):.6f}\")\n",
    "               # print(f\"Test data: mean={np.mean(x_test_scaled):.6f}, std={np.std(x_test_scaled):.6f}\")\n",
    "\n",
    "               train_mean = x_train_scaled.to_numpy().mean()\n",
    "               train_std = x_train_scaled.to_numpy().std()\n",
    "\n",
    "               test_mean = x_test_scaled.to_numpy().mean()\n",
    "               test_std = x_test_scaled.to_numpy().std()\n",
    "\n",
    "               print(f\"Train mean ≈ {train_mean:.6f}, std ≈ {train_std:.6f}\")\n",
    "               print(f\"Test mean ≈ {test_mean:.6f}, std ≈ {test_std:.6f}\")\n",
    "               return x_train_scaled, x_test_scaled\n",
    "x_train_scaled, x_test_scaled= z_scoring(x_train, x_test)"
   ]
  },
