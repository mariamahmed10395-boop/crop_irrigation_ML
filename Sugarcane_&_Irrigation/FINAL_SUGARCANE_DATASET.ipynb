    "    elif isinstance(test_data, list):\n",
    "        test_data = pd.DataFrame([test_data], columns= x_train_best_f.columns)\n",
    "\n",
    "    prediction = model.predict(test_data)[0]\n",
    "\n",
    "    return f\"Yield_Quintal_per_Acre: {prediction:.2f}\""
   ]
