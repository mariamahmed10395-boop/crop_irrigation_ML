    "Soil_Moisture= 'Soil_Moisture_%'\n",
    "Rainfall_Total_mm= 'Rainfall_Total_mm'\n",
    "Temp_Avg_C= 'Temp_Avg_C'\n",
    "Row_Gap_cm= 'Row_Gap_cm'\n",
    "Brix_Value= 'Brix_Value'\n",
