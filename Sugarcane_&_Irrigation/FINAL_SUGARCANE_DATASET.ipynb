  {
   "cell_type": "code",
   "execution_count": 266,
   "id": "e031d342",
   "metadata": {},
   "outputs": [],
   "source": [
    "def data_insert(\n",
    "    Nitrogen,\n",
    "    Disease_Severity,\n",
    "    Pest_Level,\n",
    "    Potassium,\n",
    "    Soil_Condition,\n",
    "    Soil_Moisture,\n",
    "    Rainfall_Total_mm,\n",
    "    Temp_Avg_C,\n",
    "    Row_Gap_cm,\n",
    "    Planting_Method,\n",
    "    Brix_Value,\n",
    "    Humidity\n",
    "):\n",
    "\n",
    "    data = {\n",
    "        'Nitrogen_kg_per_acre': Nitrogen,\n",
    "        'Potassium_kg_per_acre': Potassium,\n",
    "        'Soil_Moisture_%': Soil_Moisture,\n",
    "        'Rainfall_Total_mm': Rainfall_Total_mm,\n",
    "        'Temp_Avg_C': Temp_Avg_C,\n",
    "        'Row_Gap_cm': Row_Gap_cm,\n",
    "        'Brix_Value': Brix_Value,\n",
    "        'Humidity_%': Humidity,\n",
    "\n",
    "        # One-hot encoding\n",
    "        'Disease_Severity_High': 1 if Disease_Severity == 'High' else 0,\n",
    "        'Disease_Severity_Low': 1 if Disease_Severity == 'Low' else 0,\n",
    "\n",
    "        'Pest_Level_High': 1 if Pest_Level == 'High' else 0,\n",
    "        'Pest_Level_Low': 1 if Pest_Level == 'Low' else 0,\n",
    "        'Pest_Level_Medium': 1 if Pest_Level == 'Medium' else 0,\n",
    "\n",
    "        'Soil_Condition_At_Planting_Dry': 1 if Soil_Condition == 'Dry' else 0,\n",
    "        'Soil_Condition_At_Planting_Wet': 1 if Soil_Condition == 'Wet' else 0,\n",
    "        'Soil_Condition_At_Planting_Moist': 1 if Soil_Condition == 'Moist' else 0,\n",
    "\n",
    "        'Planting_Method_Trench': 1 if Planting_Method == 'Trench' else 0,\n",
    "        'Planting_Method_Paired Row': 1 if Planting_Method == 'Paired Row' else 0,\n",
    "        'Planting_Method_Straight Row': 1 if Planting_Method == 'Straight Row' else 0,\n",
    "        'Planting_Method_Circular': 1 if Planting_Method == 'Circular' else 0,\n",
    "    }\n",
    "\n",
    "    return data"
   ]
  },
