      "  - Weed_Control_Chemical & Weed_Control_Manual: -0.923\n",
      "  - Fertilizer_Split_Single & Fertilizer_Split_Split: -0.921\n",
      "  - Mulching_No & Mulching_Yes: -0.921\n",
      "  - Machinery_Use_No & Machinery_Use_Yes: -0.925\n",
      "  - Region_West_UP & Region_other: -1.000\n",
      "  - Season_Kharif & Season_Rabi: -0.926\n",
      "  - Sunshine_hour & Sunshine_hour_sin: -0.862\n",
