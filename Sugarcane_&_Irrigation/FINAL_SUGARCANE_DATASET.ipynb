   "outputs": [],
   "source": [
    "def train_poly_model_with_adam(x_train_best_f, x_test_best_f, y_train, y_test, degree=2):\n",
    "\n",
    "\n",
    "    # ================================\n",
    "    # Preprocessing \n",
    "    # ================================\n",
    "    scaler = StandardScaler()\n",
    "    X_train_scaled = scaler.fit_transform(x_train_best_f)\n",
    "    X_test_scaled = scaler.transform(x_test_best_f)\n",
    "\n",
    "    poly = PolynomialFeatures(degree=degree)\n",
    "    X_train_poly = poly.fit_transform(X_train_scaled)\n",
    "    X_test_poly = poly.transform(X_test_scaled)\n",
    "\n",
    "    # ================================\n",
    "    # Neural Network Model\n",
    "    # ================================\n",
    "\n",
    "    # Old Way\n",
    "    # model = tf.keras.Sequential([\n",
    "    #     tf.keras.layers.Dense(64, activation='relu', input_shape=(X_train_poly.shape[1],)),\n",
    "    #     tf.keras.layers.Dense(32, activation='relu'),\n",
    "    #     tf.keras.layers.Dense(1)])\n",
    "\n",
    "    # New way\n",
    "    model = tf.keras.Sequential([\n",
    "    tf.keras.layers.Input(shape=(X_train_poly.shape[1],)),\n",
    "    tf.keras.layers.Dense(64, activation='relu'),\n",
    "    tf.keras.layers.Dense(32, activation='relu'),\n",
    "    tf.keras.layers.Dense(1)])\n",
    "\n",
    "    # ================================\n",
    "    # Compile with Adam\n",
    "    # ================================\n",
    "    model.compile(\n",
    "        optimizer=tf.keras.optimizers.Adam(learning_rate=0.001),\n",
    "        loss='mse'\n",
    "    )\n",
    "\n",
    "    # ================================\n",
    "    # Training\n",
    "    # ================================\n",
    "    model.fit(X_train_poly, y_train,epochs=50,batch_size=32,verbose=0)\n",
    "\n",
    "\n",
    "    # ================================\n",
    "    # Predictions\n",
    "    # ================================\n",
    "    y_train_pred = model.predict(X_train_poly).flatten()\n",
    "    y_test_pred = model.predict(X_test_poly).flatten()\n",
    "\n",
    "\n",
    "    # ================================\n",
    "    # Evaluation\n",
    "    # ================================\n",
    "    train_r2 = r2_score(y_train, y_train_pred)\n",
    "    test_r2 = r2_score(y_test, y_test_pred)\n",
    "\n",
    "    results = {\n",
    "        \"train_r2\": train_r2,\n",
    "        \"test_r2\": test_r2,\n",
    "        \"train_mae\": mean_absolute_error(y_train, y_train_pred),\n",
    "        \"test_mae\": mean_absolute_error(y_test, y_test_pred),\n",
    "        \"train_rmse\": np.sqrt(mean_squared_error(y_train, y_train_pred)),\n",
    "        \"test_rmse\": np.sqrt(mean_squared_error(y_test, y_test_pred)),\n",
    "        \"model\": model,\n",
    "        \"scaler\": scaler,\n",
    "        \"poly\": poly\n",
    "    }\n",
    "\n",
    "    print(\"Train R2:\", train_r2)\n",
    "    print(\"Test R2:\", test_r2)\n",
    "\n",
    "    print(\"\\n----------------------------------\")\n",
    "\n",
    "    print(\"\\nOverfitting Gap:\", abs(train_r2 - test_r2))\n",
    "\n",
    "    print(\"\\n----------------------------------\")\n",
    "\n",
    "    print(\"\\nTrain MAE:\", results[\"train_mae\"])\n",
    "    print(\"Test MAE:\", results[\"test_mae\"])\n",
    "\n",
    "    print(\"\\n----------------------------------\")\n",
    "\n",
    "    print(\"\\nTrain RMSE:\", results[\"train_rmse\"])\n",
    "    print(\"Test RMSE:\", results[\"test_rmse\"])\n",
    "\n",
    "\n",
    "\n",
    "    return results"
   ]
  },
